# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...   # Public anon key (safe to expose)
SUPABASE_SERVICE_ROLE_KEY=eyJ...       # Service role key — NEVER expose to browser

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=your_64_char_random_hex_secret_here

# ─── Admin allowlist ──────────────────────────────────────────────────────────
# Comma-separated emails allowed to access /admin (e.g. toggle a user's billing
# mode to 'managed'). Admin is an operational allowlist, not a DB role.
ADMIN_EMAILS=you@yourcompany.com

# ─── Encryption ───────────────────────────────────────────────────────────────
# Used to encrypt Meta access tokens at rest. Generate with: openssl rand -hex 32
# Must be exactly 64 hex characters (32 bytes)
ENCRYPTION_KEY=your_64_char_random_hex_key_here

# ─── Meta / WhatsApp Business ─────────────────────────────────────────────────
NEXT_PUBLIC_META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret          # Used to verify webhook signatures
NEXT_PUBLIC_META_CONFIG_ID=your_embedded_signup_config_id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token  # Any random string

# ─── Razorpay ─────────────────────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Plan IDs — create in Razorpay dashboard
RAZORPAY_PLAN_STARTER_MONTHLY=plan_xxx
RAZORPAY_PLAN_STARTER_YEARLY=plan_xxx
RAZORPAY_PLAN_GROWTH_MONTHLY=plan_xxx
RAZORPAY_PLAN_GROWTH_YEARLY=plan_xxx
RAZORPAY_PLAN_PRO_MONTHLY=plan_xxx
RAZORPAY_PLAN_PRO_YEARLY=plan_xxx

# ─── Email ────────────────────────────────────────────────────────────────────
# Optional — if not set, emails are logged to console only
RESEND_API_KEY=re_xxx
EMAIL_FROM=WASend <noreply@yourdomain.com>

# ─── Anthropic (AI Reply node in automations) ─────────────────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxx

# Support WhatsApp number (E.164 digits) for the onboarding "Chat with us" button
NEXT_PUBLIC_SUPPORT_WHATSAPP=

# ─── Durable job queue (webhook processing) ───────────────────────────────────
# Default (unset) = inline driver: handlers run in-process, off the response path.
# Set to "pgboss" for a durable, Postgres-backed queue (survives crashes).
QUEUE_DRIVER=
# Required when QUEUE_DRIVER=pgboss. Use the Supabase SESSION-mode connection
# (port 5432 / session pooler) — NOT the 6543 transaction pooler (pg-boss needs
# advisory locks + LISTEN/NOTIFY). pg-boss creates/manages a "pgboss" schema.
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.your-project.supabase.co:5432/postgres
# Shared secret for the Vercel Cron drainer (/api/cron/drain-queue). Vercel sends
# it as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=
